    },
    {
      "path": "*",
      "method": "GET",
      "limit": 200,
      "window_seconds": 60
    }
  ],
  "security": {
    "block_sql_injection": true,
    "block_xss": true,
    "blacklisted_ips": [
      "203.0.113.42"
    ]
  }
}
