{
  "server": {
    "listen_port": 9090,
    "backend_url": "http://localhost:8080"
  },
  "rate_limits": [
    {
      "path": "/getAllUsers",
      "method": "GET",
      "limit": 100,
      "window_seconds": 60
    },
    {
